/**
 * @fileoverview Firestore Security Rules for a user-centric recipe and meal planning application.
 *
 * Core Philosophy: This ruleset enforces a strict user-ownership model for personal data, while
 * enabling a collaborative, shared database for common resources like ingredients and global recipes.
 * It also grants administrators full access to manage platform data and users.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description User profile documents. Admins can list and read all profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
        allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow list: if isAdmin();
        allow create: if isSignedIn() && isOwner(userId);
        allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow delete: if isAdmin(); // Only admins can delete user documents directly
    }

    /**
     * @description Recipes owned by a specific user. Admins have full access.
     * @path /users/{userId}/recipes/{recipeId}
     */
    match /users/{userId}/recipes/{recipeId} {
      allow read, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && (isExistingOwner(userId) || isAdmin());
    }

     /**
     * @description Folders for organizing recipes, owned by a specific user. Admins have full access.
     * @path /users/{userId}/folders/{folderId}
     */
    match /users/{userId}/folders/{folderId} {
      allow read, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && (isExistingOwner(userId) || isAdmin());
    }
    
    /**
     * @description Weekly meal plan documents for a specific user. Admins have full access.
     * @path /users/{userId}/weekPlan/{day}
     */
    match /users/{userId}/weekPlan/{day} {
        allow read, list: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow create: if isSignedIn() && isOwner(userId);
        allow update, delete: if isSignedIn() && (isExistingOwner(userId) || isAdmin());
    }

    /**
     * @description Meal plans owned by a specific user (legacy, may be deprecated). Admins have full access.
     * @path /users/{userId}/meal_plans/{mealPlanId}
     */
    match /users/{userId}/meal_plans/{mealPlanId} {
      allow read, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && (isExistingOwner(userId) || isAdmin());
    }
    
    /**
     * @description Ingredients owned by a specific user. Admins have full access.
     * @path /users/{userId}/ingredients/{ingredientId}
     */
    match /users/{userId}/ingredients/{ingredientId} {
      allow read, list: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && (isExistingOwner(userId) || isAdmin());
    }

    /**
     * @description Global recipes managed by administrators.
     * @path /nutriplanner_recipes/{recipeId}
     */
    match /nutriplanner_recipes/{recipeId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
    }
    
    /**
     * @description Global folders for NutriPlanner recipes, managed by administrators.
     * @path /nutriplanner_folders/{folderId}
     */
    match /nutriplanner_folders/{folderId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isAdmin();
    }

    /**
     * @description Shared, global ingredient database.
     * @path /ingredients/{ingredientId}
     */
    match /ingredients/{ingredientId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    //----------------------------------------------------------------------------------------------
    // Helper functions
    //----------------------------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.admin == true || request.auth.token.email == 'jonicheik@gmail.com');
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId));
    }
  }
}
