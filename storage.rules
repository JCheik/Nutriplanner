rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access on all files to anyone.
    // Allow write access only on files in the 'recipes' folder
    // for authenticated users, for files that are images and less than 5MB.
    match /{allPaths=**} {
      allow read;
      allow write: if request.auth != null &&
                    allPaths.matches('recipes/.*') &&
                    request.resource.contentType.matches('image/.*') &&
                    request.resource.size < 5 * 1024 * 1024;
    }
  }
}
