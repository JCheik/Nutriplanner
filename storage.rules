rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow authenticated users to write to the 'recipes' folder
    match /recipes/{imageName} {
      allow write: if request.auth != null &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 5 * 1024 * 1024;
      // Allow anyone to read images from the 'recipes' folder
      allow read;
    }

    // A good practice is to explicitly deny access to other paths
    // while still allowing public read for any other existing files if needed.
    // This rule will apply to any path that doesn't match the one above.
    match /{allPaths=**} {
        allow read;
        allow write: if false;
    }
  }
}

    