rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Recipe images live at recipes/<uid|global>/<recipeId>.<ext>.
    // They are uploaded server-side via the Admin SDK (which bypasses these
    // rules), so direct client writes aren't used in practice; this is
    // defense-in-depth. Public read is required to render the images.
    match /recipes/{ownerId}/{imageName} {
      allow read;
      allow write: if request.auth != null &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 5 * 1024 * 1024;
    }

    // Deny everything else by default — no blanket public read.
    match /{allPaths=**} {
        allow read, write: if false;
    }
  }
}
